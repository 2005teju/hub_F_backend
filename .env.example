# Port the API server runs on (Render sets this automatically, you don't
# need to set it yourself on Render — just leave it for local dev)
PORT=5000

# MongoDB Atlas connection string. Get this from Atlas -> Connect ->
# "Drivers". Replace <user> and <password> with your real DB user
# (Database Access tab), NOT your Atlas login.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nearbyhub?retryWrites=true&w=majority

# JWT secret used to sign auth tokens - change this to a long random string
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# The deployed frontend URL(s) allowed to call this API.
# Comma-separate multiple values, no spaces, no trailing slash.
# Example for local + production:
# CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
